# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Bedrock Knowledge Base (created via setup.py or AWS Console)
BEDROCK_KB_ID=
BEDROCK_KB_S3_BUCKET=my-bedrock-kb-docs

# Claude model on Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Embedding model for Knowledge Base
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Set true to use mock responses (no AWS needed)
DEMO_MODE=true
